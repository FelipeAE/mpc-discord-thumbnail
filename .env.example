# MPC-HC Web Interface
MPC_HOST=localhost
MPC_PORT=13579
# Seguridad: por defecto solo permite localhost/127.0.0.1/::1.
# Cambiar a true solo si entiendes el riesgo de exponer la interfaz web de MPC-HC en red.
ALLOW_REMOTE_MPC=false

# VLC Media Player Web Interface (opcional, si deseas usar VLC)
# VLC_HOST=localhost
# VLC_PORT=8080
# VLC_PASSWORD=tu_vlc_password_aqui

# Proveedor de subida de imágenes: imgur, catbox, o imgbb
# catbox es el más recomendado porque no requiere API key y no tiene rate limits estrictos.
UPLOAD_PROVIDER=imgur

# Imgur API - Obtener en https://api.imgur.com/oauth2/addclient (solo requerida si UPLOAD_PROVIDER=imgur)
IMGUR_CLIENT_ID=tu_imgur_client_id_aqui
IMGUR_UPLOAD_INTERVAL=75000

# ImgBB API Key - Obtener en https://api.imgbb.com/ (solo requerida si UPLOAD_PROVIDER=imgbb)
# IMGBB_API_KEY=tu_imgbb_api_key_aqui

# Discord Application - Crear en https://discord.com/developers/applications
DISCORD_CLIENT_ID=tu_discord_client_id_aqui
AUTO_RESTART_DISCORD=false
DISCORD_RESTART_THRESHOLD=60

# Consulta automática a AniList para anime (obtiene portada oficial gratis)
ENABLE_ANILIST=true

# Intervalo de actualización en milisegundos (default: 15000 = 15 segundos)
UPDATE_INTERVAL=15000

# Parámetros de compresión de imágenes
# IMAGE_MAX_WIDTH=640
# IMAGE_JPEG_QUALITY=80

# Botones interactivos en Discord (opcional, máximo 2)
# BUTTON_1_LABEL=Ver en GitHub
# BUTTON_1_URL=https://github.com/FelipeAE/mpc-discord-thumbnail
# BUTTON_2_LABEL=
# BUTTON_2_URL=

# Fix para imagen espejada con múltiples monitores (true/false)
FLIP_THUMBNAIL=false
# Flip vertical (false/true/auto)
FLIP_VERTICAL=auto
